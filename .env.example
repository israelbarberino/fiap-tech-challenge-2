# Environment Variables for Production Security

# Actuator Management Credentials
# CRITICAL: Change these default values in production!
MANAGEMENT_SECURITY_USERNAME=admin
MANAGEMENT_SECURITY_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Database Credentials (override application.properties defaults)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/user_management
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Server Configuration
SERVER_PORT=8081

# Security Notes:
# 1. Never commit .env files with real credentials to version control
# 2. Use strong passwords (minimum 16 characters, mixed alphanumeric + symbols)
# 3. In production, consider using:
#    - AWS Secrets Manager
#    - Azure Key Vault
#    - HashiCorp Vault
#    - Kubernetes Secrets
# 4. Rotate credentials regularly
# 5. Limit Actuator access to internal networks only
