{
  "info": {
    "_postman_id": "fiap-user-management-api",
    "name": "FIAP User Management API",
    "description": "Coleção completa de requisições para a API de Gerenciamento de Usuários",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Validar Credenciais",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"joao.silva\",\n  \"password\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/validate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "validate"]
            },
            "description": "Valida as credenciais de login de um usuário"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Usuários",
      "item": [
        {
          "name": "Criar Usuário",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva\",\n  \"email\": \"joao.silva@example.com\",\n  \"login\": \"joao.silva\",\n  \"password\": \"senha123\",\n  \"role\": \"CUSTOMER\",\n  \"address\": {\n    \"street\": \"Rua das Flores\",\n    \"number\": \"123\",\n    \"complement\": \"Apt 45\",\n    \"city\": \"São Paulo\",\n    \"state\": \"SP\",\n    \"zipCode\": \"01234-567\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"]
            },
            "description": "Cria um novo usuário no sistema"
          },
          "response": []
        },
        {
          "name": "Obter Usuário por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "1"]
            },
            "description": "Obtém os dados de um usuário específico"
          },
          "response": []
        },
        {
          "name": "Buscar Usuários por Nome",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users?name=João",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"],
              "query": [
                {
                  "key": "name",
                  "value": "João"
                }
              ]
            },
            "description": "Busca usuários pelo nome (case-insensitive)"
          },
          "response": []
        },
        {
          "name": "Atualizar Usuário",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva Atualizado\",\n  \"email\": \"joao.silva.novo@example.com\",\n  \"role\": \"RESTAURANT_OWNER\",\n  \"address\": {\n    \"street\": \"Avenida Paulista\",\n    \"number\": \"1000\",\n    \"complement\": \"Sala 50\",\n    \"city\": \"São Paulo\",\n    \"state\": \"SP\",\n    \"zipCode\": \"01311-100\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "1"]
            },
            "description": "Atualiza as informações de um usuário existente"
          },
          "response": []
        },
        {
          "name": "Alterar Senha",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"senha123\",\n  \"newPassword\": \"novaSenha456\",\n  \"confirmPassword\": \"novaSenha456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/1/password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "1", "password"]
            },
            "description": "Altera a senha de um usuário"
          },
          "response": []
        },
        {
          "name": "Deletar Usuário",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "1"]
            },
            "description": "Deleta um usuário do sistema"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health"]
            },
            "description": "Verifica o status de saúde da aplicação"
          },
          "response": []
        },
        {
          "name": "Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/info",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "info"]
            },
            "description": "Obtém informações sobre a aplicação"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}
